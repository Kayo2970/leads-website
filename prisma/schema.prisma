generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Application {
  id        Int      @id @default(autoincrement())
  fullName  String
  email     String
  phone     String?
  year      String
  faculty   String
  interest  String
  whyJoin   String
  createdAt DateTime @default(now())
}
